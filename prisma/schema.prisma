generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Employee {
  id               String        @id @default(cuid()) @map("_id")
  employee_code    String?       @unique
  email            String?       @unique
  password         String?
  name             String
  display_name     String
  default_language String        @default("Mixed")
  status           String        @default("active")
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt
  calls            Call[]
  upload_batches   UploadBatch[]

  @@map("employees")
}

model AnalysisHead {
  id                     String         @id @default(cuid()) @map("_id")
  name                   String         @unique
  description            String?
  status                 String         @default("active")
  default_master_file_id String?
  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt
  call_scenarios         CallScenario[]
  calls                  Call[]
  upload_batches         UploadBatch[]
  master_files           MasterFile[]

  @@map("analysis_heads")
}

model CallScenario {
  id               String        @id @default(cuid()) @map("_id")
  analysis_head_id String
  analysis_head    AnalysisHead  @relation(fields: [analysis_head_id], references: [id])
  name             String
  description      String?
  status           String        @default("active")
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt
  calls            Call[]
  upload_batches   UploadBatch[]

  @@unique([analysis_head_id, name])
  @@map("call_scenarios")
}

model MasterFile {
  id               String        @id @default(cuid()) @map("_id")
  title            String
  version          String
  scope            String        @default("global")
  analysis_head_id String?
  analysis_head    AnalysisHead? @relation(fields: [analysis_head_id], references: [id])
  file_url         String
  extracted_text   String?
  is_active        Boolean       @default(false)
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  @@map("master_files")
}

model Call {
  id                      String       @id @map("_id")
  employee_id             String
  employee                Employee     @relation(fields: [employee_id], references: [id])
  analysis_head_id        String
  analysis_head           AnalysisHead @relation(fields: [analysis_head_id], references: [id])
  call_scenario_id        String
  call_scenario           CallScenario @relation(fields: [call_scenario_id], references: [id])
  call_datetime           DateTime
  file_name               String
  audio_url               String
  duration_seconds        Int?
  transcription_status    String       @default("pending")
  transcript_text         String?
  raw_transcript_json_url String?
  analysis_status         String       @default("pending")
  analysis_text           String?
  raw_analysis_json_url   String?
  analysis_error          String?
  analyzed_at             DateTime?
  language_detected       String?
  speaker_count           Int?
  notes                   String?
  upload_batch_id         String?
  upload_batch            UploadBatch? @relation(fields: [upload_batch_id], references: [id])
  created_at              DateTime     @default(now())
  updated_at              DateTime     @updatedAt

  @@map("calls")
}

model UploadBatch {
  id               String       @id @default(cuid()) @map("_id")
  uploaded_by      String?
  employee_id      String
  employee         Employee     @relation(fields: [employee_id], references: [id])
  analysis_head_id String
  analysis_head    AnalysisHead @relation(fields: [analysis_head_id], references: [id])
  call_scenario_id String
  call_scenario    CallScenario @relation(fields: [call_scenario_id], references: [id])
  batch_date       DateTime
  total_files      Int          @default(0)
  completed_files  Int          @default(0)
  failed_files     Int          @default(0)
  sheet_file_name   String?
  sheet_file_url    String?
  sheet_text        String?
  report_status    String       @default("pending")
  report_text      String?
  report_file_url  String?
  report_error     String?
  report_generated_at DateTime?
  notes            String?
  calls            Call[]
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  @@map("upload_batches")
}
