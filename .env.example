# Session authentication
JWT_SECRET="your-random-32-plus-char-secret"

# MongoDB connection string (local or Atlas)
# Local:  mongodb://localhost:27017/ai_call_analyzer
# Atlas:  mongodb+srv://user:password@cluster.mongodb.net/ai_call_analyzer?retryWrites=true&w=majority
DATABASE_URL="mongodb://localhost:27017/ai_call_analyzer"

# Amazon S3 storage
S3_BUCKET_NAME="your-s3-bucket-name"
S3_REGION="your-s3-region"
S3_ACCESS_KEY_ID="your-s3-access-key-id"
S3_SECRET_ACCESS_KEY="your-s3-secret-access-key"

# ElevenLabs Speech-to-Text
ELEVENLABS_API_KEY="your-elevenlabs-api-key"

# OpenAI analysis
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o"
