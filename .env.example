# Admin authentication
ADMIN_EMAIL_ID="admin@example.com"
ADMIN_PASSWORD="your-admin-password"
JWT_SECRET="your-random-32-plus-char-secret"

# MongoDB connection string (local or Atlas)
# Local:  mongodb://localhost:27017/ai_call_analyzer
# Atlas:  mongodb+srv://user:password@cluster.mongodb.net/ai_call_analyzer?retryWrites=true&w=majority
DATABASE_URL="mongodb://localhost:27017/ai_call_analyzer"

# Cloudinary storage
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# AssemblyAI Speech-to-Text
ASSEMBLYAI_API_KEY="your-assemblyai-api-key"

# Gemini Analysis
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-3.5-flash"
