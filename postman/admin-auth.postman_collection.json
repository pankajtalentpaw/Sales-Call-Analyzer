{
  "info": {
    "_postman_id": "0ed63b70-8446-4f6c-9be9-f8f4a4759238",
    "name": "AI Call Analyzer - Admin Auth",
    "description": "Requests for testing admin login and cookie-based admin access.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Admin Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login succeeds', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json()).to.eql({ ok: true });",
              "});",
              "",
              "pm.test('Admin session cookie is set', function () {",
              "  pm.expect(pm.cookies.has('admin_session')).to.equal(true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"emailId\": \"{{adminEmailId}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Check Admin Access",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Admin API is accessible after login', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is an array', function () {",
              "  pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/admin/employees",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "employees"
          ]
        }
      },
      "response": []
    }
  ]
}
